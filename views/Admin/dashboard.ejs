<!DOCTYPE html>
<html dir="rtl" lang="fa">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>پنل - <%= user.name %></title>
    <link rel="stylesheet" href="/bootstrap/css/bootstrap.min.css">
    <link rel="stylesheet" href="/fonts/font-awesome.min.css">
    <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>

<div class="dashboard-layout">
    
    <!-- ========== سایدبار ========== -->
    <aside class="sidebar">
        <div class="sidebar-header">
            <img src="<%= user.avatar ? '/img/avatar/' + user.avatar : '/img/defualtPic.png' %>" 
                 alt="<%= user.name %>" class="sidebar-avatar">
            <h5 class="sidebar-name"><%= user.name %></h5>
            <div class="sidebar-roles">
                <% user.roles.forEach(role => { %>
                    <span class="sidebar-role-badge <%= role.toLowerCase() %>"><%= role %></span>
                <% }); %>
            </div>
        </div>
        
        <ul class="sidebar-menu">
            <li>
                <a href="/dashboard" class="active">
                    <i class="fa fa-home"></i> پنل مدیریت
                </a>
            </li>
            <li>
                <a href="/">
                    <i class="fa fa-globe"></i> صفحه اصلی
                </a>
            </li>
            <li>
                <a href="/auth/logout" style="color: #ff6b6b;">
                    <i class="fa fa-sign-out"></i> خروج از حساب کاربری
                </a>
            </li>
        </ul>
    </aside>

    <!-- ========== محتوا ========== -->
    <main class="main-content">
        
        <!-- هدر -->
        <div class="page-header">
            <h2><i class="fa fa-dashboard"></i> داشبورد</h2>
            <span class="date"><%= new Date().toLocaleDateString('fa-IR') %></span>
        </div>

        <% // ==================== ADMIN ==================== %>
        <% if (user.roles.includes("ADMIN")) { %>
            
            <!-- آمار -->
            <div class="stats-grid">
                <div class="stat-card blue">
                    <div class="stat-icon"><i class="fa fa-users"></i></div>
                    <div class="stat-number"><%= totalUsers %></div>
                    <div class="stat-label">کاربران</div>
                </div>
                <div class="stat-card green">
                    <div class="stat-icon"><i class="fa fa-book"></i></div>
                    <div class="stat-number"><%= totalCourses %></div>
                    <div class="stat-label">دوره‌ها</div>
                </div>
                <div class="stat-card orange">
                    <div class="stat-icon"><i class="fa fa-comments"></i></div>
                    <div class="stat-number"><%= totalComments %></div>
                    <div class="stat-label">کامنت‌ها</div>
                </div>
                <div class="stat-card red">
                    <div class="stat-icon"><i class="fa fa-shopping-cart"></i></div>
                    <div class="stat-number"><%= totalOrders %></div>
                    <div class="stat-label">سفارشات</div>
                </div>
                <div class="stat-card purple">
                    <div class="stat-icon"><i class="fa fa-video-camera"></i></div>
                    <div class="stat-number"><%= totalSessions %></div>
                    <div class="stat-label">جلسات</div>
                </div>
                <div class="stat-card teal">
                    <div class="stat-icon"><i class="fa fa-file-text"></i></div>
                    <div class="stat-number"></div>
                    <div class="stat-label">مقالات</div>
                </div>
            </div>

            <!-- آخرین سفارشات -->
            <% if (recentOrders && recentOrders.length > 0) { %>
                <div class="content-card">
                    <h5 class="card-title"><i class="fa fa-clock-o"></i> آخرین سفارشات</h5>
                    <div class="item-list">
                        <% recentOrders.forEach(order => { %>
                            <div class="item-row">
                                <div class="item-info">
                                    <div class="item-details">
                                        <p class="item-name"><%= order.user.name %></p>
                                        <span class="item-meta"><%= order.user.email %></span>
                                    </div>
                                </div>
                                <div class="item-actions">
                                    <span class="badge badge-info"><%= order.items.length %> دوره</span>
                                    <span class="item-meta"><%= new Date(order.createdAt).toLocaleDateString('fa-IR') %></span>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                </div>
            <% } %>

        <% } %>

        <% // ==================== TEACHER ==================== %>
        <% if (user.roles.includes("TEACHER")) { %>
            
            <!-- جلسات -->
            <div class="content-card">
                <h5 class="card-title"><i class="fa fa-video-camera"></i> جلسات ایجاد شده (<%= mySessions.length %>)</h5>
                <% if (mySessions.length > 0) { %>
                    <div class="item-list">
                        <% mySessions.forEach(session => { %>
                            <div class="item-row">
                                <div class="item-info">
                                    <div class="item-details">
                                        <p class="item-name"><%= session.title %></p>
                                        <span class="item-meta">دوره: <%= session.course ? session.course.name : '---' %></span>
                                    </div>
                                </div>
                                <div class="item-actions">
                                    <span class="badge <%= session.isFree ? 'badge-free' : 'badge-paid' %>">
                                        <%= session.isFree ? 'رایگان' : 'پولی' %>
                                    </span>
                                    <span class="item-meta"><%= session.duration || 0 %> دقیقه</span>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                <% } else { %>
                    <div class="empty-state">
                        <i class="fa fa-video-camera"></i>
                        <p>جلسه‌ای ایجاد نشده است</p>
                    </div>
                <% } %>
            </div>

            <!-- کامنت‌های دوره‌های مدرس -->
            <div class="content-card">
                <h5 class="card-title"><i class="fa fa-comments"></i> کامنت‌های دوره‌های من (<%= courseComments.length %>)</h5>
                <% if (courseComments.length > 0) { %>
                    <div class="item-list">
                        <% courseComments.forEach(comment => { %>
                            <div class="item-row">
                                <div class="item-info">
                                    <img src="<%= comment.user?.avatar ? '/img/avatar/' + comment.user.avatar : '/img/defualtPic.png' %>" 
                                         alt="" class="item-thumb" style="width: 40px; height: 40px;">
                                    <div class="item-details">
                                        <p class="item-name"><%= comment.user?.name || 'کاربر' %></p>
                                        <span class="comment-preview"><%= comment.content %></span>
                                    </div>
                                </div>
                                <div class="item-actions">
                                    <span class="stars">
                                        <% for (let i = 1; i <= 5; i++) { %>
                                            <i class="fa fa-star<%= i <= comment.rating ? '' : '-o' %>"></i>
                                        <% } %>
                                    </span>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                <% } else { %>
                    <div class="empty-state">
                        <i class="fa fa-comment-o"></i>
                        <p>کامنتی برای دوره‌های شما ثبت نشده</p>
                    </div>
                <% } %>
            </div>

        <% } %>

        <% // ==================== AUTHOR ==================== %>


        <% // ==================== USER ==================== %>
        <% if (user.roles.includes("USER")) { %>
            
            <!-- دوره‌های من -->
            <div class="content-card">
                <h5 class="card-title"><i class="fa fa-book"></i> دوره‌های خریداری شده (<%= myCourses.length %>)</h5>
                <% if (myCourses.length > 0) { %>
                    <div class="item-list">
                        <% myCourses.forEach(item => { %>
                            <div class="item-row">
                                <div class="item-info">
                                    <img src="/img/cover/<%= item.course.cover || 'default.jpg' %>" 
                                         alt="<%= item.course.name %>" class="item-thumb">
                                    <div class="item-details">
                                        <p class="item-name"><%= item.course.name %></p>
                                        <span class="item-meta"><%= new Date(item.purchaseDate).toLocaleDateString('fa-IR') %></span>
                                    </div>
                                </div>
                                <div class="item-actions">
                                    <span class="price-text"><%= item.price.toLocaleString() %> تومان</span>
                                    <a href="/course/<%= item.course.href %>" class="btn-dashboard btn-primary-dash">
                                        <i class="fa fa-eye"></i> مشاهده
                                    </a>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                <% } else { %>
                    <div class="empty-state">
                        <i class="fa fa-shopping-cart"></i>
                        <p>هنوز دوره‌ای خریداری نکرده‌اید</p>
                        <a href="/course" class="btn-dashboard btn-primary-dash">مشاهده دوره‌ها</a>
                    </div>
                <% } %>
            </div>

            <!-- کامنت‌های من -->
            <div class="content-card">
                <h5 class="card-title"><i class="fa fa-comments"></i> کامنت‌های من (<%= myComments.length %>)</h5>
                <% if (myComments.length > 0) { %>
                    <div class="item-list">
                        <% myComments.forEach(comment => { %>
                            <div class="item-row">
                                <div class="item-info">
                                    <div class="item-details">
                                        <p class="item-name"><%= comment.course ? comment.course.name : 'دوره حذف شده' %></p>
                                        <span class="comment-preview"><%= comment.content %></span>
                                    </div>
                                </div>
                                <div class="item-actions">
                                    <span class="stars">
                                        <% for (let i = 1; i <= 5; i++) { %>
                                            <i class="fa fa-star<%= i <= comment.rating ? '' : '-o' %>"></i>
                                        <% } %>
                                    </span>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                <% } else { %>
                    <div class="empty-state">
                        <i class="fa fa-comment-o"></i>
                        <p>کامنتی ثبت نشده است</p>
                    </div>
                <% } %>
            </div>

        <% } %>

    </main>
</div>

</body>
</html>