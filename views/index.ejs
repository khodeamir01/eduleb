    <div class="container">
        <!-- بخش عنوان و دکمه مشاهده همه -->
        <div class="row">
            <div class="col-lg-8 col-sm-6 col-xs-12">
                <div class="section-title">
                    <h2>با بیش از <b><%= locals.totalCourses || '0' %>+</b><br>دوره و آموزش</h2>
                </div>
            </div>
            <div class="col-lg-4 col-sm-6 col-xs-12">
                <div class="cour_btn">
                    <a href="/courses" class="btn_one">مشاهده تمام دوره ها<i class="ti-arrow-top-left"></i></a>
                </div>
            </div>
        </div>

        <!-- بخش لیست دوره‌ها -->
        <div class="row">
            <% if (locals.courses && courses.length > 0) { %>

                <% courses.forEach(function(course) { %>
                    <div class="col-lg-4 col-sm-6 col-xs-12">
                        <div class="single_course">
                            <div class="single_c_img">
                                <!-- نمایش تصویر کاور -->
                                <img src="<%= course.cover ? 'img/cover/' + course.cover : 'img/course/1.png' %>" class="img-fluid" alt="<%= course.name %>">
                                
                                <!-- نمایش دسته‌بندی (با استفاده از populate) -->
                                <span><%= course.categoryID ? course.categoryID.title : 'بدون دسته' %></span>
                            </div>

                            <!-- ستاره‌ها (می‌توانی از rating دیتابیس استفاده کنی یا ثابت بگذاری) -->
                            <i class="fa fa-star"></i>
                            <i class="fa fa-star"></i>
                            <i class="fa fa-star"></i>
                            <i class="fa fa-star"></i>
                            <i class="fa fa-star"></i>

                            <h4><a href="/course/<%= course.href %>"><%= course.name %></a></h4>

                            <!-- تعداد دوره و زمان (اگر در دیتابیس داری جایگزین کن، در غیر این صورت متن ثابت) -->
                            <p><span class="ti-book"></span><%= course.lessonsCount || '12' %> جلسه</p>
                            <p><span class="ti-alarm-clock"></span><%= course.duration || '2 ساعت و 32 دقیقه' %></p>

                            <!-- نمایش قیمت -->
                            <div class="price">
                                <% if (course.price === 0) { %>
                                    هزینه دوره - رایگان
                                <% } else { %>
                                    هزینه دوره - <%= course.price.toLocaleString() %> تومان
                                <% } %>
                            </div>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <!-- اگر دوره‌ای وجود نداشت -->
                <div class="col-12 text-center">
                    <p>در حال حاضر دوره‌ای برای نمایش وجود ندارد.</p>
                </div>
            <% } %>
        </div>
    </div>
</section>
