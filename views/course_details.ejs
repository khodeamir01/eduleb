                        <div class="col-md-4 col-12 mb-3">
                          <div class="rating-selection">
                            <span class="rating-title">امتیاز شما :</span>
                            <div class="stars">
                              <% for (let i = 5; i >= 1; i--) { %>
                              <i
                                class="fa fa-star-o star-selectable"
