                                    type="submit"
                                    class="custom-button rounded"
                                  >
                                    ارسال پاسخ
                                  </button>
                                  <button
                                    type="button"
                                    class="custom-button rounded cancel-reply"
                                    data-comment-id="<%= comment._id %>"
                                  >
                                    انصراف
                                  </button>
                                </div>
                              </form>
                            </div>

