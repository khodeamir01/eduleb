      cancelButtonColor: "#3085d6",
      reverseButtons: true
    });

    if (result.isConfirmed) {
      try {
        Swal.fire({
          title: "در حال حذف پاسخ...",
          allowOutsideClick: false,
          didOpen: () => {
            Swal.showLoading();
          },
        });

        const response = await fetch(`/comments/${commentId}/reply/${replyId}`, {
          method: "DELETE",
          headers: {
            "Content-Type": "application/json",
          },
        });

        const data = await response.json();

        if (data.success) {
          Swal.fire({
            icon: "success",
            title: "حذف شد!",
            text: "پاسخ با موفقیت حذف شد",
            timer: 2000,
            showConfirmButton: false
          });

          // حذف عنصر Reply از DOM
          const replyElement = document.getElementById(`reply-${replyId}`);
          if (replyElement) {
            replyElement.remove();
            
            // بررسی کن آیا replies دیگه‌ای باقی مونده
            const repliesSection = replyElement.closest(".replies-section");
            if (repliesSection && repliesSection.children.length === 0) {
              repliesSection.remove();
            }
          }
        } else {
          Swal.fire({
            icon: "error",
            title: "خطا",
