                          <span class="star-container">
                            <i class="fa fa-star <%= i >= replyRating ? 'gold-star' : 'gray-star' %>" style="font-size: 12px;"></i>
                          </span>
                        <% } %>
                      </div>
                      
                      <p style="font-size: 13px;"><%= reply.content %></p>
                                <!-- دکمه حذف Reply -->
          <% if (user && reply.user && user._id.toString() === reply.user._id.toString()) { %>
            <button 
              class="delete-reply-btn" 
              data-comment-id="<%= comment._id %>" 
              data-reply-id="<%= reply._id %>"
              style="
                margin-top: 8px;
                padding: 4px 12px;
                background-color: #ff4757;
                color: white;
                border: none;
                border-radius: 4px;
                cursor: pointer;
                font-size: 12px;
                transition: all 0.3s ease;
              "
              onmouseover="this.style.backgroundColor='#ff3838'"
              onmouseout="this.style.backgroundColor='#ff4757'"
            >
              <i class="fa fa-trash"></i> حذف پاسخ
            </button>
          <% } %>
                    </div>
                  </li>
                <% }); %>
              </div>
            <% } %>
                        <% }); %> <% } else { %>
                        <p>هنوز نظری برای این دوره ثبت نشده است.</p>
                        <% } %>
                      </ul>
                    </div>

