            confirmButtonColor: "#667eea"
          });
        }
      } catch (error) {
        console.error("خطا:", error);
        Swal.fire({
          icon: "error",
          title: "خطا",
          text: "خطا در ارتباط با سرور",
          confirmButtonText: "باشه",
          confirmButtonColor: "#667eea"
        });
      }
    }
  });
});
      document.addEventListener("DOMContentLoaded", function () {
        
        // ============= مدیریت ستاره‌های کامنت اصلی =============
        const mainStars = document.querySelectorAll("#reviewForm .star-selectable");
        const mainRatingInput = document.getElementById("selectedRating");
        setupStarSystem(mainStars, mainRatingInput);
      
        // ============= مدیریت ستاره‌های Reply =============
        const replyStarGroups = document.querySelectorAll(".reply-stars");
        replyStarGroups.forEach((starGroup) => {
          const commentId = starGroup.getAttribute("data-comment-id");
          const replyStars = starGroup.querySelectorAll(".reply-star");
          const replyRatingInput = document.querySelector(
            `.reply-rating[data-comment-id="${commentId}"]`
          );
          setupStarSystem(replyStars, replyRatingInput);
        });
      
        // ============= تابع اصلی مدیریت ستاره‌ها =============
        function setupStarSystem(stars, ratingInput) {
          function highlightStars(rating) {
            const starsArray = Array.from(stars);
            starsArray.forEach((star) => {
              const starRating = parseInt(star.getAttribute("data-rating"));
              if (starRating >= rating) {
                star.classList.remove("fa-star-o");
                star.classList.add("fa-star");
                star.style.color = "#FFD700";
              } else {
                star.classList.remove("fa-star");
                star.classList.add("fa-star-o");
                star.style.color = "#FFD700";
              }
            });
          }
      
          function setRating(rating) {
            ratingInput.value = rating;
            highlightStars(rating);
          }
      
          stars.forEach((star) => {
            star.addEventListener("click", function () {
              const rating = parseInt(this.getAttribute("data-rating"));
              setRating(rating);
            });
      
            star.addEventListener("mouseenter", function () {
              const rating = parseInt(this.getAttribute("data-rating"));
              highlightStars(rating);
            });
      
            star.addEventListener("mouseleave", function () {
              const currentRating = parseInt(ratingInput.value);
              if (currentRating === 0) {
                resetStars();
              } else {
                highlightStars(currentRating);
              }
            });
          });
      
          function resetStars() {
            stars.forEach((star) => {
              star.classList.remove("fa-star");
              star.classList.add("fa-star-o");
              star.style.color = "#FFD700";
            });
          }
      
          resetStars();
        }
      
        // ============= مدیریت نمایش/مخفی کردن فرم Reply =============
        const showReplyButtons = document.querySelectorAll(".show-reply-form");
        const cancelReplyButtons = document.querySelectorAll(".cancel-reply");
      
        showReplyButtons.forEach((button) => {
          button.addEventListener("click", function () {
            const commentId = this.getAttribute("data-comment-id");
            const replyForm = document.getElementById(`replyForm-${commentId}`);
      
            document.querySelectorAll(".reply-form").forEach((form) => {
              form.style.display = "none";
            });
      
            if (replyForm) {
              replyForm.style.display = "block";
            }
          });
        });
      
        cancelReplyButtons.forEach((button) => {
          button.addEventListener("click", function () {
            const commentId = this.getAttribute("data-comment-id");
            const replyForm = document.getElementById(`replyForm-${commentId}`);
      
            if (replyForm) {
              const textarea = replyForm.querySelector(".reply-textarea");
              const ratingInput = replyForm.querySelector(".reply-rating");
              
              // اگر متنی نوشته شده، تأیید بگیر
              if (textarea && textarea.value.trim() !== "") {
                Swal.fire({
                  title: "انصراف از پاسخ؟",
                  text: "متن نوشته شده پاک می‌شود",
                  icon: "question",
                  showCancelButton: true,
                  confirmButtonText: "بله، منصرف شدم",
                  cancelButtonText: "ادامه نوشتن",
                  confirmButtonColor: "#d33",
                  cancelButtonColor: "#3085d6",
                  reverseButtons: true
                }).then((result) => {
                  if (result.isConfirmed) {
                    hideReplyForm(replyForm, textarea, ratingInput);
                  }
                });
              } else {
                hideReplyForm(replyForm, textarea, ratingInput);
              }
            }
          });
        });
      
        function hideReplyForm(replyForm, textarea, ratingInput) {
          replyForm.style.display = "none";
          if (textarea) textarea.value = "";
          if (ratingInput) ratingInput.value = "0";
          
          const stars = replyForm.querySelectorAll(".reply-star");
          stars.forEach((star) => {
            star.classList.remove("fa-star");
            star.classList.add("fa-star-o");
            star.style.color = "#FFD700";
          });
        }
      
        // ============= ارسال فرم Reply با SweetAlert2 =============
        document.querySelectorAll(".reply-form-element").forEach((form) => {
          form.addEventListener("submit", async function (e) {
            e.preventDefault();
      
            const commentId = this.closest(".reply-form").id.replace("replyForm-", "");
            const ratingInput = this.querySelector(".reply-rating");
            const contentInput = this.querySelector(".reply-textarea");
      
            const rating = parseInt(ratingInput?.value || 0);
            const content = contentInput?.value?.trim() || "";
      
            // اعتبارسنجی با SweetAlert2
            if (rating === 0) {
              Swal.fire({
                icon: "warning",
                title: "اخطار",
                text: "لطفاً امتیاز خود را انتخاب کنید",
                confirmButtonText: "باشه",
              });
              return;
            }
      
            if (content === "") {
              Swal.fire({
                icon: "warning",
                title: "اخطار",
                text: "لطفاً پاسخ خود را بنویسید",
                confirmButtonText: "باشه",
              });
              return;
            }
      
            try {
              // نمایش لودینگ
              Swal.fire({
                title: "در حال ثبت پاسخ...",
                allowOutsideClick: false,
                didOpen: () => {
                  Swal.showLoading();
                },
              });
      
              const response = await fetch(`/comments/${commentId}/reply`, {
                method: "POST",
                headers: {
                  "Content-Type": "application/json",
                },
                body: JSON.stringify({
                  rating: rating,
                  content: content,
                }),
              });
      
              const data = await response.json();
      
              if (data.success) {
                Swal.fire({
                  icon: "success",
                  title: "پاسخ ثبت شد! 🎉",
                  text: "پاسخ شما با موفقیت ارسال شد",
                  confirmButtonText: "رفتن به صفحه اصلی",
                  showCancelButton: true,
                  cancelButtonText: "ماندن در صفحه",
                  reverseButtons: true,
                }).then((result) => {
                  if (result.isConfirmed) {
                    window.location.href = "/";
                  } else {
                    location.reload();
                  }
                });
              } else {
                Swal.fire({
                  icon: "error",
                  title: "خطا",
                  text: data.error || "مشکلی در ثبت پاسخ پیش آمد",
                  confirmButtonText: "باشه",
                });
              }
            } catch (error) {
              console.error("Error:", error);
              Swal.fire({
                icon: "error",
                title: "خطا",
                text: "خطا در ارتباط با سرور",
                confirmButtonText: "باشه",
              });
            }
          });
        });
      
        // ============= ارسال فرم کامنت اصلی با SweetAlert2 =============
        document.getElementById("reviewForm")?.addEventListener("submit", async (e) => {
          e.preventDefault();
      
          const rating = parseInt(mainRatingInput.value);
          const content = document.getElementById("commentInput").value.trim();
      
          if (rating === 0) {
            Swal.fire({
              icon: "warning",
              title: "اخطار",
              text: "لطفاً امتیاز خود را انتخاب کنید",
              confirmButtonText: "باشه",
            });
            return;
          }
      
          if (content === "") {
            Swal.fire({
              icon: "warning",
              title: "اخطار",
              text: "لطفاً نظر خود را بنویسید",
              confirmButtonText: "باشه",
            });
            return;
          }
      
          try {
            Swal.fire({
              title: "در حال ثبت نظر...",
              allowOutsideClick: false,
              didOpen: () => {
                Swal.showLoading();
              },
            });
      
            const response = await fetch("/comments/<%= course.href %>/create", {
              method: "POST",
              headers: {
                "Content-Type": "application/json",
              },
              body: JSON.stringify({
                rating: rating,
                content: content,
              }),
            });
      
            const data = await response.json();
      
            if (data.success) {
              Swal.fire({
                icon: "success",
                title: "موفقیت",
                text: "نظر شما با موفقیت ثبت شد",
                confirmButtonText: "رفتن به صفحه اصلی",
                showCancelButton: true,
                cancelButtonText: "ماندن در صفحه",
                reverseButtons: true,
              }).then((result) => {
                if (result.isConfirmed) {
                  window.location.href = "/";
                } else {
                  location.reload();
                }
              });
            } else {
              Swal.fire({
                icon: "error",
                title: "خطا",
                text: data.error || "مشکلی در ثبت نظر پیش آمد",
                confirmButtonText: "باشه",
              });
            }
          } catch (error) {
            console.error("Error:", error);
            Swal.fire({
              icon: "error",
              title: "خطا",
              text: "خطا در ارتباط با سرور",
              confirmButtonText: "باشه",
            });
          }
        });
      
        // ============= حذف کامنت با SweetAlert2 =============
        document.querySelectorAll(".delete-comment-btn").forEach((button) => {
          button.addEventListener("click", async function () {
            const commentId = this.getAttribute("data-comment-id");
            
            const result = await Swal.fire({
              title: "حذف کامنت",
              text: "آیا مطمئن هستید که می‌خواهید این کامنت را حذف کنید؟",
              icon: "warning",
              showCancelButton: true,
              confirmButtonText: "بله، حذف کن",
              cancelButtonText: "انصراف",
              confirmButtonColor: "#d33",
              cancelButtonColor: "#3085d6",
              reverseButtons: true
            });
      
            if (result.isConfirmed) {
              try {
                Swal.fire({
                  title: "در حال حذف...",
                  allowOutsideClick: false,
                  didOpen: () => {
                    Swal.showLoading();
                  },
                });
      
                const response = await fetch(`/comments/${commentId}`, {
                  method: "DELETE",
                  headers: {
                    "Content-Type": "application/json",
                  },
                });
      
                const data = await response.json();
      
                if (data.success) {
                  Swal.fire({
                    icon: "success",
                    title: "حذف شد!",
                    text: "کامنت با موفقیت حذف شد",
                    timer: 2000,
                    showConfirmButton: false
                  });
      
                  const commentElement = document.getElementById(`comment-${commentId}`);
                  if (commentElement) {
                    commentElement.remove();
                  }
      
                  const reviewContents = document.querySelector(".review-contents");
                  if (reviewContents && reviewContents.children.length === 0) {
                    reviewContents.innerHTML = "<p>هنوز نظری برای این دوره ثبت نشده است.</p>";
                  }
                } else {
                  Swal.fire({
                    icon: "error",
                    title: "خطا",
                    text: data.error || "خطا در حذف کامنت",
                    confirmButtonText: "باشه",
                  });
                }
              } catch (error) {
                console.error("خطا:", error);
                Swal.fire({
                  icon: "error",
                  title: "خطا",
                  text: "خطا در ارتباط با سرور",
                  confirmButtonText: "باشه",
                });
              }
            }
          });
        });
      
      });
