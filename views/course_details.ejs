                              src="<%= comment.user.avatar ? '/img/avatar/' + comment.user.avatar : '/img/defualtPic.png' %>"
                              alt="user"
                            />
                          </div>
                          <div class="cont">
                            <h6 class="subtitle"><%= comment.user.name %></h6>
                            <div class="ratings cl-theme">
                              <% const rating = parseInt(comment.rating) || 0; %>
                              <% for (let i = 5; i >= 1; i--) { %>
                                <span class="star-container">
                                  <i class="fa fa-star <%= i >= rating ? 'gold-star' : 'gray-star' %>"></i>
                                </span>
                              <% } %>
                            </div>

