                            <li>
                                <i class="fa fa-trophy"></i>
                                <span>گواهینامه: <b>دارد</b></span>
                            </li>
                        </ul>
                    </div>
                    
                    <div class="event_info_price"><h4>قیمت - <%= course.price %> تومان</h4></div>
                    <div class="event_info_register"><a class="btn_one" href="#">امروز ثبت نام کنید</a></div>
                    
                    <div class="related_course">
                        <h3>دیگر دوره های مرتبط</h3>
                        <% if (relatedCourses && relatedCourses.length > 0) { %>
                            <% relatedCourses.forEach(function(relCourse) { %>
                                <div class="single_rc">
                                    <div class="rc_img">
                                        <img src="/img/cover/<%= relCourse.cover %>" alt="<%= relCourse.name %>">
                                    </div>
                                    <i class="fa fa-star"></i><i class="fa fa-star"></i>
                                    <h4><a href="/course/<%= relCourse._id %>"><%= relCourse.name %></a></h4>
                                    <span><%= relCourse.price %> تومان</span>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <p>دوره مرتبطی یافت نشد.</p>
                        <% } %>
                    </div>
                    
                    <div class="sidebar-post">
                        <div class="sidebar_title"><h4>دسته بندی ها</h4></div>
                        <% if (locals.categories && categories.length > 0) { %>
                            <div class="single_category">
                                <ul>
                                    <% categories.forEach(function(category) { %>
                                        <li>
                                            <a href="/categories/<%= category.href %>">
                                                <%= category.title %>
                                            </a>
                                        </li>
                                    <% }); %>
                                </ul>
                            </div>
