<!DOCTYPE html>
<html dir="rtl" lang="fa">
<head>
  <meta charset="utf-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
  <title>سبد خرید - <%= user.name %></title>
  <link rel="stylesheet" href="/bootstrap/css/bootstrap.min.css" />
  <link href="https://fonts.googleapis.com/css2?family=Inria+Sans:ital,wght@0,300;0,400;0,700;1,300;1,400;1,700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/fonts/font-awesome.min.css" />
  <link rel="stylesheet" href="/css/style.css" />
  
  <style>
    :root {
      --cart-primary: #525fe1;
      --cart-accent: #f26b65;
      --cart-bg: #f8f9fb;
      --card-shadow: 0 10px 40px rgba(0,0,0,0.06);
    }

    body { background: var(--cart-bg); }

    .cart-container {
      padding: 50px 0;
      min-height: 80vh;
    }

    /* ========== هدر سبد خرید ========== */
    .cart-hero {
      background: linear-gradient(135deg, #1a1a2e 0%, #302b63 100%);
      border-radius: 24px;
      padding: 40px;
      margin-bottom: 40px;
      color: white;
      position: relative;
      overflow: hidden;
    }

    .cart-hero::before {
      content: '';
      position: absolute;
      top: -40%;
      right: -20%;
      width: 400px;
      height: 400px;
      background: rgba(82,95,225,0.15);
      border-radius: 50%;
      animation: cartPulse 6s ease-in-out infinite;
    }

    @keyframes cartPulse {
      0%, 100% { transform: scale(1); opacity: 0.5; }
      50% { transform: scale(1.2); opacity: 0.8; }
    }

    .cart-hero-content {
      position: relative;
      z-index: 1;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 20px;
    }

    .cart-hero h1 {
      font-size: 32px;
      margin: 0;
      background: linear-gradient(135deg, #fff, #e0e0ff);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .cart-hero p { margin: 5px 0 0; opacity: 0.8; }

    .cart-badge {
      background: rgba(255,255,255,0.15);
      backdrop-filter: blur(10px);
      padding: 12px 24px;
      border-radius: 50px;
      font-size: 14px;
      display: flex;
      align-items: center;
      gap: 8px;
      border: 1px solid rgba(255,255,255,0.2);
    }

    /* ========== محتوای اصلی ========== */
    .cart-layout {
      display: grid;
      grid-template-columns: 1fr 380px;
      gap: 30px;
    }

    /* ========== کارت محصول ========== */
    .cart-item-card {
      background: white;
      border-radius: 20px;
      padding: 24px;
      margin-bottom: 20px;
      display: flex;
      gap: 24px;
      box-shadow: var(--card-shadow);
      transition: all 0.3s ease;
      border: 1px solid #f0f0f0;
    }

    .cart-item-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 15px 50px rgba(0,0,0,0.1);
    }

    .cart-item-cover {
      width: 200px;
      height: 130px;
      border-radius: 14px;
      overflow: hidden;
      flex-shrink: 0;
      position: relative;
    }

    .cart-item-cover img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s;
    }

    .cart-item-card:hover .cart-item-cover img {
      transform: scale(1.05);
    }

    .cart-item-info {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .cart-item-name {
      font-size: 18px;
      font-weight: 700;
      color: #1a1a2e;
      margin: 0 0 8px;
    }

    .cart-item-name a {
      color: inherit;
      text-decoration: none;
      transition: color 0.3s;
    }

    .cart-item-name a:hover { color: var(--cart-primary); }

    .cart-item-teacher {
      display: flex;
      align-items: center;
      gap: 10px;
      color: #666;
      font-size: 13px;
    }

    .cart-item-teacher img {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      object-fit: cover;
      border: 2px solid #f0f0f0;
    }

    .cart-item-footer {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: auto;
    }

    .cart-item-price {
      font-size: 22px;
      font-weight: 800;
      background: linear-gradient(135deg, #525fe1, #f26b65);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .cart-item-price small {
      font-size: 13px;
      -webkit-text-fill-color: #999;
    }

    .btn-remove {
      background: #fff;
      border: 2px solid #ff4757;
      color: #ff4757;
      padding: 10px 20px;
      border-radius: 12px;
      cursor: pointer;
      font-size: 13px;
      font-weight: 600;
      transition: all 0.3s;
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .btn-remove:hover {
      background: #ff4757;
      color: white;
      transform: scale(1.05);
    }

    /* ========== سایدبار ========== */
    .cart-sidebar {
      position: sticky;
      top: 20px;
      align-self: start;
    }

    .summary-card {
      background: white;
      border-radius: 20px;
      padding: 32px;
      box-shadow: var(--card-shadow);
      border: 1px solid #f0f0f0;
    }

    .summary-card h3 {
      font-size: 20px;
      font-weight: 700;
      margin-bottom: 25px;
      padding-bottom: 15px;
      border-bottom: 2px solid #f0f0f0;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .summary-row {
      display: flex;
      justify-content: space-between;
      margin-bottom: 14px;
      font-size: 14px;
      color: #666;
    }

    .summary-total {
      display: flex;
      justify-content: space-between;
      margin-top: 20px;
      padding-top: 20px;
      border-top: 2px solid #f0f0f0;
      font-size: 18px;
      font-weight: 700;
    }

    .total-price {
      font-size: 26px;
      font-weight: 800;
      background: linear-gradient(135deg, #525fe1, #f26b65);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .btn-checkout {
      width: 100%;
      padding: 16px;
      background: linear-gradient(135deg, #525fe1, #f26b65);
      color: white;
      border: none;
      border-radius: 14px;
      font-size: 16px;
      font-weight: 700;
      cursor: pointer;
      margin-top: 25px;
      transition: all 0.3s;
      box-shadow: 0 10px 25px rgba(82,95,225,0.3);
    }

    .btn-checkout:hover {
      transform: translateY(-2px);
      box-shadow: 0 15px 35px rgba(82,95,225,0.4);
    }

    .btn-continue {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      margin-top: 16px;
      color: #666;
      text-decoration: none;
      font-size: 14px;
      transition: color 0.3s;
    }

    .btn-continue:hover { color: var(--cart-primary); }

    /* ========== خالی ========== */
    .empty-state {
      text-align: center;
      padding: 100px 20px;
    }

    .empty-state-icon {
      width: 120px;
      height: 120px;
      background: linear-gradient(135deg, #f0f0f0, #e0e0e0);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 30px;
      font-size: 50px;
      color: #ccc;
    }

    .empty-state h2 {
      font-size: 24px;
      color: #333;
      margin-bottom: 10px;
    }

    .empty-state p { color: #999; margin-bottom: 30px; }

    .btn-browse {
      display: inline-block;
      padding: 14px 35px;
      background: linear-gradient(135deg, #525fe1, #f26b65);
      color: white;
      border-radius: 14px;
      text-decoration: none;
      font-weight: 700;
      transition: all 0.3s;
    }

    .btn-browse:hover {
      transform: translateY(-2px);
      box-shadow: 0 15px 35px rgba(82,95,225,0.4);
      color: white;
      text-decoration: none;
    }

    /* ========== انیمیشن ========== */
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .cart-item-card {
      animation: fadeInUp 0.5s ease forwards;
    }

    /* ========== ریسپانسیو ========== */
    @media (max-width: 768px) {
      .cart-layout {
        grid-template-columns: 1fr;
      }
      
      .cart-item-card {
        flex-direction: column;
      }
      
      .cart-item-cover {
        width: 100%;
        height: 180px;
      }
      
      .cart-hero {
        padding: 30px 20px;
      }
      
      .cart-hero h1 { font-size: 24px; }
    }
  </style>
</head>
<body>

  <!-- نویگیشن -->
  <div id="navigation" class="navbar-light bg-faded site-navigation">
    <!-- هدر سایت -->
  </div>

  <section class="cart-container">
    <div class="container">
      
      <!-- هدر -->
      <div class="cart-hero">
        <div class="cart-hero-content">
          <div>
            <h1><i class="fa fa-shopping-cart"></i> سبد خرید</h1>
            <p><%= user.name %> عزیز، دوره‌های انتخابی شما</p>
          </div>
          <% if (cart && cart.items) { %>
            <div class="cart-badge">
              <i class="fa fa-book"></i>
              <%= cart.items.length %> دوره
            </div>
          <% } %>
        </div>
      </div>

      <% if (isEmpty || !cart) { %>
        
        <div class="empty-state">
          <div class="empty-state-icon">
            <i class="fa fa-shopping-cart"></i>
          </div>
          <h2>سبد خرید شما خالی است</h2>
          <p>هنوز هیچ دوره‌ای انتخاب نکرده‌اید</p>
          <a href="/course" class="btn-browse">
            <i class="fa fa-search"></i> مشاهده دوره‌ها
          </a>
        </div>

      <% } else { %>

        <div class="cart-layout">
          
          <!-- لیست دوره‌ها -->
          <div class="cart-items-list">
            <% cart.items.forEach(item => { %>
              <div class="cart-item-card" id="cart-item-<%= item.course._id %>">
                <div class="cart-item-cover">
                  <a href="/course/<%= item.course.href %>">
                    <img src="/img/cover/<%= item.course.cover || 'default.jpg' %>" alt="<%= item.course.name %>">
                  </a>
                </div>
                <div class="cart-item-info">
                  <div>
                    <h4 class="cart-item-name">
                      <a href="/course/<%= item.course.href %>"><%= item.course.name %></a>
                    </h4>
                    <div class="cart-item-teacher">
                      <img src="<%= item.teacher?.avatar ? '/img/avatar/' + item.teacher.avatar : '/img/defualtPic.png' %>" alt="">
                      <span><%= item.teacher?.name || 'مدرس' %></span>
                    </div>
                  </div>
                  <div class="cart-item-footer">
                    <div class="cart-item-price">
                      <%= item.priceAtTime?.toLocaleString() %> <small>تومان</small>
                    </div>
                    <button class="btn-remove remove-from-cart" data-course-id="<%= item.course._id %>">
                      <i class="fa fa-trash"></i> حذف
                    </button>
                  </div>
                </div>
              </div>
            <% }); %>
          </div>

          <!-- سایدبار -->
          <div class="cart-sidebar">
            <div class="summary-card">
              <h3><i class="fa fa-receipt"></i> خلاصه سفارش</h3>
              
              <div class="summary-row">
                <span><i class="fa fa-book"></i> تعداد دوره‌ها</span>
                <span><%= cart.items.length %> دوره</span>
              </div>
              
              <div class="summary-row">
                <span><i class="fa fa-clock-o"></i> مدت تقریبی</span>
                <span><%= cart.items.length * 12 %> ساعت</span>
              </div>
              
              <div class="summary-total">
                <span>مبلغ قابل پرداخت</span>
                <span class="total-price"><%= totalPrice.toLocaleString() %> تومان</span>
              </div>
              
              <button class="btn-checkout" onclick="goToPayment()">
                <i class="fa fa-credit-card"></i> پرداخت و ثبت نام
              </button>
              
              <a href="/course" class="btn-continue">
                <i class="fa fa-arrow-right"></i> ادامه خرید
              </a>
            </div>
          </div>

        </div>

      <% } %>

    </div>
  </section>

  <!-- فوتر -->
  <div class="footer section-padding">
    <!-- فوتر -->
  </div>

  <!-- اسکریپت‌ها -->
  <script src="/js/sweetAlert2.js"></script>
  <script src="/js/jquery-1.12.4.min.js"></script>
  <script src="/bootstrap/js/bootstrap.min.js"></script>
  <script src="/js/scripts.js"></script>

  <script>
    // ============= حذف از سبد خرید =============
    document.querySelectorAll('.remove-from-cart').forEach(button => {
      button.addEventListener('click', async function() {
        const courseId = this.getAttribute('data-course-id');
        
        const result = await Swal.fire({
          title: "حذف از سبد خرید",
          text: "آیا مطمئن هستید؟",
          icon: "warning",
          showCancelButton: true,
          confirmButtonText: "بله، حذف کن",
          cancelButtonText: "انصراف",
          confirmButtonColor: "#dc3545",
          cancelButtonColor: "#6c757d",
          reverseButtons: true
        });

        if (!result.isConfirmed) return;

        Swal.fire({ title: "در حال حذف...", allowOutsideClick: false, didOpen: () => Swal.showLoading() });

        try {
          const response = await fetch('/cart/remove', {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ courseId })
          });
          const data = await response.json();

          if (data.success) {
            document.getElementById(`cart-item-${courseId}`)?.remove();
            Swal.fire({ icon: 'success', title: 'حذف شد!', timer: 1500, showConfirmButton: false });
            setTimeout(() => location.reload(), 1500);
          } else {
            Swal.fire({ icon: 'error', title: 'خطا', text: data.error });
          }
        } catch (error) {
          Swal.fire({ icon: 'error', title: 'خطا', text: 'خطا در ارتباط با سرور' });
        }
      });
    });

    // ============= پرداخت =============
    async function goToPayment() {
      Swal.fire({ title: 'در حال اتصال به درگاه...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });

      try {
        const response = await fetch('/checkout/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' }
        });
        const data = await response.json();

        if (data.success && data.data?.paymentUrl) {
          Swal.fire({
            icon: 'success',
            title: 'اتصال برقرار شد',
            text: 'در حال انتقال به درگاه...',
            timer: 2000,
            showConfirmButton: false
          }).then(() => { window.location.href = data.data.paymentUrl; });
        } else {
          Swal.fire({ icon: 'error', title: 'خطا', text: data.error || 'مشکلی پیش آمد' });
        }
      } catch (error) {
        Swal.fire({ icon: 'error', title: 'خطا', text: 'خطا در ارتباط با سرور' });
      }
    }
  </script>

</body>
</html>