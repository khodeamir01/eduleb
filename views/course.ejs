    <section class="home_course section-padding">
      <div class="container">
        <section class="home_course section-padding">
            <div class="container">
              
              <!-- ========== فرم فیلتر ========== -->
              <div style="background: #f8f9fa; padding: 20px; border-radius: 12px; margin-bottom: 30px;">
                <form action="/course" method="GET">
                  <div class="row align-items-end">
                    
                    <!-- جستجو -->
                    <div class="col-md-4 mb-3">
                      <label style="font-size: 14px; margin-bottom: 5px; display: block;">جستجو</label>
                      <input type="text" name="search" class="form-control" 
                             placeholder="نام دوره..." 
                             value="<%= locals.filters ? filters.search : '' %>">
                    </div>
          
                    <!-- دسته‌بندی -->
                    <div class="col-md-2 mb-3">
                      <label style="font-size: 14px; margin-bottom: 5px; display: block;">دسته‌بندی</label>
                      <select name="category" class="form-control">
                        <option value="">همه</option>
                        <% if (categories) { %>
                          <% categories.forEach(function(cat) { %>
                            <option value="<%= cat._id %>" 
                              <%= (locals.filters && filters.category === cat._id.toString()) ? 'selected' : '' %>>
                              <%= cat.title %>
                            </option>
                          <% }); %>
                        <% } %>
                      </select>
                    </div>
          
                    <!-- نوع قیمت -->
                    <div class="col-md-2 mb-3">
                      <label style="font-size: 14px; margin-bottom: 5px; display: block;">نوع دوره</label>
                      <select name="priceType" class="form-control">
                        <option value="all" <%= (locals.filters && filters.priceType === 'all') ? 'selected' : '' %>>همه</option>
                        <option value="free" <%= (locals.filters && filters.priceType === 'free') ? 'selected' : '' %>>رایگان</option>
                        <option value="paid" <%= (locals.filters && filters.priceType === 'paid') ? 'selected' : '' %>>پولی</option>
                      </select>
                    </div>
          
                    <!-- مرتب‌سازی -->
                    <div class="col-md-2 mb-3">
                      <label style="font-size: 14px; margin-bottom: 5px; display: block;">مرتب‌سازی</label>
                      <select name="sort" class="form-control">
                        <option value="newest" <%= (locals.filters && filters.sort === 'newest') ? 'selected' : '' %>>جدیدترین</option>
                        <option value="oldest" <%= (locals.filters && filters.sort === 'oldest') ? 'selected' : '' %>>قدیمی‌ترین</option>
                        <option value="priceAsc" <%= (locals.filters && filters.sort === 'priceAsc') ? 'selected' : '' %>>ارزان‌ترین</option>
                        <option value="priceDesc" <%= (locals.filters && filters.sort === 'priceDesc') ? 'selected' : '' %>>گران‌ترین</option>
                      </select>
                    </div>
          
                    <!-- دکمه‌ها -->
                    <div class="col-md-2 mb-3">
                      <label style="font-size: 14px; margin-bottom: 5px; display: block;">&nbsp;</label>
                      <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-sm" style="background: #667eea; border: none;">
                          <i class="fa fa-search"></i>
                        </button>
                        <a href="/course" class="btn btn-outline-secondary btn-sm">
                          <i class="fa fa-times"></i>
                        </a>
                      </div>
                    </div>
          
                  </div>
                </form>
              </div>
              <!-- ========== پایان فیلتر ========== -->
          
              <!-- نمایش تعداد نتایج -->
              <div style="margin-bottom: 20px; color: #666; font-size: 14px;">
                <span><%= totalCourses %> دوره یافت شد</span>
                <% if (locals.filters && filters.search) { %>
                  <span>برای جستجوی "<%= filters.search %>"</span>
                <% } %>
              </div>
          
              <!-- ========== لیست دوره‌ها ========== -->
              <div class="row">
                <% if (courses && courses.length > 0) { %>
          
                  <% courses.forEach(function(course) { %>
                    <div class="col-lg-4 col-sm-6 col-xs-12">
                      <div class="single_course">
                        <div class="single_c_img">
                          <img src="/img/cover/<%= course.cover || 'default.jpg' %>" 
                               class="img-fluid" alt="<%= course.name %>"
                               onerror="this.src='/img/course/1.png'">
                          
                          <span>
                            <% if (course.categoryID) { %>
                              <%= course.categoryID.title %>
                            <% } else { %>
                              بدون دسته
                            <% } %>
                          </span>
                        </div>
          
                        <!-- ستاره‌ها -->
                        <div style="margin: 8px 0;">
                          <i class="fa fa-star" style="color: #FFD700;"></i>
                          <i class="fa fa-star" style="color: #FFD700;"></i>
                          <i class="fa fa-star" style="color: #FFD700;"></i>
                          <i class="fa fa-star" style="color: #FFD700;"></i>
                          <i class="fa fa-star" style="color: #FFD700;"></i>
                        </div>
          
                        <h4><a href="/course/<%= course.href %>"><%= course.name %></a></h4>
          
                        <!-- مدرس -->
                        <% if (course.creator) { %>
                          <p style="color: #666; font-size: 13px; margin: 5px 0;">
                            <i class="fa fa-user"></i> <%= course.creator.name %>
                          </p>
                        <% } %>
          
                        <p><span class="ti-book"></span> <%= course.lessonsCount || '12' %> جلسه</p>
                        <p><span class="ti-alarm-clock"></span> <%= course.duration || '2 ساعت و 32 دقیقه' %></p>
          
                        <!-- قیمت -->
                        <div class="price" style="font-size: 18px; font-weight: bold; margin-top: 10px;">
                          <% if (course.price === 0) { %>
                            <span style="color: #28a745;">رایگان</span>
                          <% } else { %>
                            <span style="color: #667eea;"><%= course.price.toLocaleString() %> تومان</span>
                          <% } %>
                        </div>
                      </div>
                    </div>
                  <% }); %>
          
                <% } else { %>
                  <div class="col-12 text-center" style="padding: 50px 0;">
                    <i class="fa fa-search" style="font-size: 60px; color: #ddd; display: block; margin-bottom: 20px;"></i>
                    <h5>دوره‌ای یافت نشد</h5>
                    <p style="color: #999;">با فیلترهای دیگه جستجو کنید</p>
                    <a href="/course" class="btn btn-primary mt-3" style="background: #667eea;">مشاهده همه دوره‌ها</a>
                  </div>
                <% } %>
              </div>
          
<!-- ========== Pagination ========== -->
<% if (totalPages > 1) { %>
    <div class="pagination-container">
      <ul class="pagination-list">
        
        <!-- دکمه قبلی -->
        <% if (currentPage > 1) { %>
          <li class="pagination-item">
            <a href="?page=<%= currentPage - 1 %>&search=<%= filters.search %>&category=<%= filters.category %>&priceType=<%= filters.priceType %>&sort=<%= filters.sort %>" 
               class="pagination-link pagination-prev">
              <i class="fa fa-angle-right"></i> قبلی
            </a>
          </li>
        <% } %>
  
        <!-- شماره صفحات -->
        <% 
          let startPage = Math.max(1, currentPage - 2);
          let endPage = Math.min(totalPages, currentPage + 2);
          
          // نقطه‌چین اول
          if (startPage > 1) { 
        %>
          <li class="pagination-item">
            <a href="?page=1&search=<%= filters.search %>&category=<%= filters.category %>&priceType=<%= filters.priceType %>&sort=<%= filters.sort %>" 
               class="pagination-link">1</a>
          </li>
          <% if (startPage > 2) { %>
            <li class="pagination-item"><span class="pagination-dots">...</span></li>
          <% } %>
        <% } %>
  
        <!-- صفحات -->
        <% for (let i = startPage; i <= endPage; i++) { %>
          <li class="pagination-item">
            <a href="?page=<%= i %>&search=<%= filters.search %>&category=<%= filters.category %>&priceType=<%= filters.priceType %>&sort=<%= filters.sort %>" 
               class="pagination-link <%= i === currentPage ? 'active' : '' %>">
              <%= i %>
            </a>
          </li>
        <% } %>
  
        <!-- نقطه‌چین آخر -->
        <% if (endPage < totalPages) { %>
          <% if (endPage < totalPages - 1) { %>
            <li class="pagination-item"><span class="pagination-dots">...</span></li>
          <% } %>
          <li class="pagination-item">
            <a href="?page=<%= totalPages %>&search=<%= filters.search %>&category=<%= filters.category %>&priceType=<%= filters.priceType %>&sort=<%= filters.sort %>" 
               class="pagination-link"><%= totalPages %></a>
          </li>
        <% } %>
  
        <!-- دکمه بعدی -->
        <% if (currentPage < totalPages) { %>
          <li class="pagination-item">
            <a href="?page=<%= currentPage + 1 %>&search=<%= filters.search %>&category=<%= filters.category %>&priceType=<%= filters.priceType %>&sort=<%= filters.sort %>" 
               class="pagination-link pagination-next">
              بعدی <i class="fa fa-angle-left"></i>
            </a>
          </li>
        <% } %>
  
      </ul>
    </div>
  <% } %>
          
            </div>
          </section>
      </div>
