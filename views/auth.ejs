<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <link rel="stylesheet" href="/css/auth.css">
    <title>ورود به پنل</title>
</head>
<body>

<div class="auth-container">
    <h2 id="title">ورود به پنل کاربری</h2>
    
    <% if (typeof error !== 'undefined') { %>
        <p class="error-msg"><%= error %></p>
    <% } %>

    <!-- فرم ارسال شماره -->
    <div id="phoneSection">
        <input type="text" id="phone" placeholder="شماره موبایل (مثلا 0912...)" required>
        <button onclick="sendOTP()">ارسال کد تایید</button>
    </div>

    <!-- فرم تایید کد -->
    <div id="otpSection" style="display: none;">
        <input type="text" id="otp" placeholder="کد ۴ رقمی" maxlength="4">
        <button onclick="verifyOTP()">تایید و ورود</button>
    </div>
</div>

<script>
    let currentPhone = "";

    async function sendOTP() {
        currentPhone = document.getElementById('phone').value;
        const res = await fetch('/auth/send', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ phone: currentPhone })
        });
        
        if (res.ok) {
            document.getElementById('phoneSection').style.display = 'none';
            document.getElementById('otpSection').style.display = 'block';
            document.getElementById('title').innerText = "کد تایید را وارد کنید";
        } else {
            alert("خطا در ارسال کد");
        }
    }

    async function verifyOTP() {
        const otp = document.getElementById('otp').value;
        const res = await fetch('/auth/verify', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ phone: currentPhone, otp })
        });
        
        if (res.ok) {
            window.location.href = "/";
        } else {
            alert("کد اشتباه است");
        }
    }
</script>
</body>
</html>
