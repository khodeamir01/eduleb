<!DOCTYPE html>
<html lang="fa" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>وارد شوید - سبزبلاگ</title>
    <link rel="stylesheet" href="/css/login.css" />
    <link rel="stylesheet" href="/css/register.css">
  </head>
  <body>
    <section class="container">
      <form action="/auth/register" method="post" class="form register-form">
        <div class="left-side image-bg"></div>
        <div class="form-content">
          <header>
            <p class="welcome">خوش آمدید !</p>
            <div class="go-register-text">
              <p>حساب کاربری دارید؟</p>
              <a href="/auth/login">وارد شوید!</a>
            </div>

            <div class="login-methods">
              <div>
                <a href="/auth/google">
                  <img src="/img/google.png" alt="" class="login-logo" />
                  ورود با گوگل
                </a>
              </div>
            </div>
          </header>
            <main class="form-main">
              <p class="or">یا ثبت نام با :</p>

              <div class="inputs-container">
                <input class="form-input fullName" name="name" type="text" placeholder="نام و نام خانوادگی ...">
                <input class="form-input username" name="username" type="text" placeholder="نام کاربری ...">
                <input class="form-input email" name="email" type="email" placeholder="آدرس ایمیل ...">
                <input class="form-input password" name="password" type="password" placeholder="گذرواژه ...">

                <input type="text" name="captcha" placeholder="متن داخل عکس را وارد کنید ...">
                <input type="hidden" class="uuid" name="uuid">

                <!-- کپچا -->
                <div class="captcha-wrapper">
                  <div class="captcha"></div>
                </div>

                <!-- دکمه -->
                <button class="login-button">وارد شوید</button>
              </div>
            </main>

        
            </div>
          </main>
        </div>
      </form>
    </section>
    <script>
      (async function () {
        const captcha = document.querySelector(".captcha");
        const uuid = document.querySelector(".uuid");

        const res = await fetch("/captcha");
        const response = await res.json();

        console.log(response);
        uuid.value = response.uuid;
        captcha.innerHTML = response.captcha
      })()

    </script>

<script src="/js/sweetAlert2.js"></script>

<% if (locals.messages && locals.messages.error) { %>
<script>
  Swal.fire({
    title: "Error",
    text: "<%= locals.messages.error %>",
    icon: "error",
    confirmButtonText: "Try Again",
  });
</script>
<% } %>

<% if (locals.messages && locals.messages.success) { %>
<script>
  Swal.fire({
    title: "Success",
    text: "<%= locals.messages.success %>",
    icon: "success",
    confirmButtonText: "Ok",
  }).then(() => {
    window.location.href = "<%= locals.messages.redirect %>";
  });
</script>
<% } %>


  </body>
</html>
